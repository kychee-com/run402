---
/**
 * `<SignIn />` — Renders a form that POSTs to the platform's hosted
 * `/auth/sign-in` route. The platform mints the browser session +
 * 303-redirects to `returnTo` on success.
 *
 * Anonymous visitors see the email/password form. Already-signed-in
 * visitors get a redirect back to `returnTo` (no point re-rendering
 * sign-in for someone with an active session).
 *
 * The default render carries NO client-side JavaScript — it's a plain HTML
 * form that submits to the platform. CSRF protection comes from the
 * gateway's Origin enforcement; for hosted routes the gateway is also
 * the authoritative double-submit verifier (no token visible to anon
 * visitors — sign-in has no session to derive from).
 *
 * ## `methods` — declarative multi-method sign-in
 *
 * Pass `methods` to render more than the built-in email/password form. The
 * methods render in the order given, separated by an "or" divider:
 *
 *   - `"password"`   (default) — the email/password `<form action="/auth/sign-in">`. **No JS.**
 *   - `"magic_link"` — a separate form posting to `/auth/magic-link/send`
 *                      (the gateway emails a link + returns a non-enumerating 200). **No JS.**
 *   - `"google"`     — a link to `/auth/sign-in/oauth/google/start?returnTo=…`
 *                      (the gateway 303s through Google + mints the cookie on callback). **No JS.**
 *   - `"passkey"`    — a button + a small WebAuthn `<script>` that drives the
 *                      hosted `/auth/passkeys/login/options` → `/verify` ceremony.
 *                      This is the ONLY method that ships client JS — WebAuthn
 *                      (`navigator.credentials.get`) is a browser-only API. The
 *                      button hides itself when `window.PublicKeyCredential` is
 *                      unavailable. The `<script>` is bundled/hoisted by Astro.
 *
 * **Additive-minor DOM contract (§6.1/§6.3 "Non-breaking no-slot upgrade").**
 * When `methods` is omitted/undefined OR exactly `["password"]`, the rendered
 * DOM, class names, `<slot/>`, and `<style>` are BYTE-IDENTICAL to the prior
 * component. Existing consumers upgrading see zero change. The extra method
 * entries + the extended `.r402-*` styles render only when other methods are
 * present.
 *
 * Capability `auth-aware-ssr` / `auth-hosted-surface-parity` / spec `hosted-auth-ui`.
 *
 * Usage:
 *   ```astro
 *   ---
 *   import { SignIn } from "@run402/astro/components";
 *   ---
 *   <SignIn returnTo="/dashboard" />
 *   <SignIn returnTo="/dashboard" methods={["password", "google", "passkey"]} />
 *   ```
 */

import {
  type SignInMethod,
  isDefaultOnly,
  normalizeMethods,
  includesPassword,
  buildExtraMethodsHtml,
  EXTRA_METHOD_CSS,
  PASSKEY_SCRIPT,
  messageForAuthError,
  AUTH_ERROR_PARAM,
} from "./sign-in-methods.js";

interface Props {
  /** Where to send the visitor after a successful sign-in. Must be a
   *  path-relative URL (begins `/` but not `//`) or a same-origin
   *  absolute URL — the gateway validates this server-side and returns
   *  R402_AUTH_RETURN_TO_INVALID for everything else. */
  returnTo?: string;
  /** Optional extra class applied to the form wrapper. */
  class?: string;
  /** Which sign-in methods to render, in this order. Defaults to
   *  `["password"]`. `"password"` / `"magic_link"` / `"google"` are no-JS;
   *  `"passkey"` ships a small WebAuthn script. Omitting it (or passing
   *  exactly `["password"]`) keeps the byte-identical default render. */
  methods?: Array<SignInMethod>;
}

const { returnTo = "/", class: className = "", methods } = Astro.props;

// §6.1/§6.3: the default case renders the verbatim original markup below.
const defaultOnly = isDefaultOnly(methods);
const resolved = normalizeMethods(methods);
const hasPassword = includesPassword(resolved);
const hasPasskey = resolved.includes("passkey");
// hosted-auth-signin-error-ssr: a FAILED hosted OAuth sign-in returns the
// visitor here with `?r402_auth_error=<code>` (a server-readable query param —
// see the @run402/astro README). Render it server-side; no client JS. When the
// param is absent nothing renders, and the default (password-only) branch never
// touches it, so the byte-identical default contract (§6.1/§6.3) holds.
const authErrorMessage = messageForAuthError(Astro.url.searchParams.get(AUTH_ERROR_PARAM));
// Where the gateway returns a FAILED OAuth sign-in: this same sign-in page
// (path only, so the error code can't accumulate across attempts). The gateway
// validates it same-origin and delivers `?r402_auth_error=` there. Rides the
// google start link below.
const errorReturnTo = Astro.url.pathname;

// Extra (non-password) method markup, divider-interleaved. A leading divider
// is added when the password form was rendered just above (so "or" sits
// between password and the next method).
const extraMethodsHtml = buildExtraMethodsHtml(resolved, returnTo, hasPassword, errorReturnTo);

// §6.1/§6.3 byte-identical default: when `methods` is omitted or exactly
// ["password"], the `defaultOnly` branch below renders the verbatim
// pre-change component (same DOM, classes, slot, surrounding whitespace).
// The multi-method `<div>` branch renders only when other methods are present.
---
{defaultOnly ? (
<form
  method="POST"
  action="/auth/sign-in"
  autocomplete="on"
  class={`r402-sign-in ${className}`.trim()}
  data-r402-sign-in
>
  <input type="hidden" name="returnTo" value={returnTo} />

  <label class="r402-field">
    <span class="r402-label">Email</span>
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      class="r402-input"
    />
  </label>

  <label class="r402-field">
    <span class="r402-label">Password</span>
    <input
      type="password"
      name="password"
      required
      autocomplete="current-password"
      class="r402-input"
    />
  </label>

  <button type="submit" class="r402-submit">Sign in</button>
  <!-- Slot for consumer-supplied extras (OAuth buttons, a magic-link link,
       a "forgot password" link, extra fields). Empty by default, so the
       zero-config render preserves the prior DOM (§6.1/§6.3). -->
  <slot />
</form>
) : (
  <div class={`r402-sign-in-methods ${className}`.trim()} data-r402-sign-in-methods>
    {authErrorMessage && (
      <div class="r402-auth-error" role="alert">{authErrorMessage}</div>
    )}
    {hasPassword && (
      <form
        method="POST"
        action="/auth/sign-in"
        autocomplete="on"
        class="r402-sign-in"
        data-r402-sign-in
      >
        <input type="hidden" name="returnTo" value={returnTo} />

        <label class="r402-field">
          <span class="r402-label">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="r402-input"
          />
        </label>

        <label class="r402-field">
          <span class="r402-label">Password</span>
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="r402-input"
          />
        </label>

        <button type="submit" class="r402-submit">Sign in</button>
      </form>
    )}
    <Fragment set:html={extraMethodsHtml} />
    {hasPasskey && <script set:html={PASSKEY_SCRIPT} is:inline />}
    <!-- Slot for consumer-supplied extras; empty by default. §6.1/§6.3. -->
    <slot />
  </div>
)}
<style>
  /* Styling is intentionally minimal — consumers override via the
     `class` prop or by re-styling `.r402-*` selectors in their global
     CSS. The defaults render a usable form without any host CSS. */
  .r402-sign-in {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 24rem;
    margin: 0 auto;
  }
  .r402-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .r402-label {
    font-size: 0.875rem;
    font-weight: 500;
  }
  .r402-input {
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    border: 1px solid var(--r402-border, #ccc);
    border-radius: var(--r402-radius, 0.375rem);
  }
  .r402-submit {
    padding: 0.625rem 1rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--r402-button-fg, #fff);
    background: var(--r402-button-bg, #111);
    border: 0;
    border-radius: var(--r402-radius, 0.375rem);
    cursor: pointer;
  }
  .r402-submit:hover {
    background: var(--r402-button-hover-bg, #333);
  }
</style>

{!defaultOnly && (
  <!-- Extra method chrome. is:global because the method markup is spliced via
       set:html and therefore carries no scoped-style attribute; these rules
       target the .r402-* method classes the same way the consumer would. -->
  <style is:global set:html={`
  .r402-sign-in-methods {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 24rem;
    margin: 0 auto;
  }
  .r402-sign-in-methods .r402-sign-in {
    margin: 0;
    max-width: none;
  }
${EXTRA_METHOD_CSS}`} />
)}
