{
  "name": "@run402/gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=../../.env src/server.ts",
    "start": "node dist/server.js",
    "test:unit": "node --experimental-test-module-mocks --test --import tsx 'src/**/*.test.ts'",
    "test:unit:coverage": "c8 --reporter=text --reporter=html --reporter=json --exclude='src/**/*.test.ts' --exclude='node_modules/**' --exclude='dist/**' --exclude='src/services/kvs.ts' node --experimental-test-module-mocks --test --import tsx 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1019.0",
    "@aws-sdk/client-cloudfront-keyvaluestore": "^3.1019.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-kms": "^3.1024.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sesv2": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@aws-sdk/signature-v4a": "^3.1009.0",
    "@bugsnag/js": "^8.8.1",
    "@bugsnag/plugin-express": "^8.8.0",
    "@coinbase/cdp-sdk": "^1.44.0",
    "@coinbase/x402": "^2.1.0",
    "@run402/shared": "1.0.0",
    "@x402/core": "^2.4.0",
    "@x402/evm": "^2.4.0",
    "@x402/express": "^2.4.0",
    "@x402/extensions": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "bs58": "^4.0.1",
    "croner": "^10.0.1",
    "esbuild": "^0.25.0",
    "express": "^5.1.0",
    "jose": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "mppx": "^0.4.7",
    "pg": "^8.13.0",
    "stripe": "^20.4.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "c8": "^11.0.0",
    "dotenv": "^16.4.0",
    "libpg-query": "^17.7.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
