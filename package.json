{
  "name": "agentdb",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/gateway",
    "packages/mcp",
    "infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:gateway": "npm run build -w packages/gateway",
    "build:infra": "npm run build -w infra",
    "build:mcp": "npm run build -w packages/mcp",
    "dev": "npm run dev -w packages/gateway",
    "test:e2e": "tsx test/e2e.ts",
    "test:mcp": "node --test --import tsx packages/mcp/src/**/*.test.ts",
    "test:mcp:e2e": "tsx test/mcp-e2e.ts",
    "deploy": "bash scripts/deploy.sh"
  }
}
