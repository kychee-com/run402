{
  "name": "run402",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/functions",
    "packages/gateway",
    "infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:gateway": "npm run build -w packages/gateway",
    "build:infra": "npm run build -w infra",
    "dev": "npm run dev -w packages/gateway",
    "test:e2e": "tsx test/e2e.ts",
    "test:openclaw": "tsx test/openclaw-e2e.ts",
    "test:subdomains": "node --experimental-test-module-mocks --test --import tsx packages/gateway/src/services/subdomains.test.ts",
    "test:contact": "node --experimental-test-module-mocks --test --import tsx packages/gateway/src/routes/contact.test.ts",
    "test:admin-sql": "node --experimental-test-module-mocks --test --import tsx packages/gateway/src/routes/admin-sql.test.ts",
    "test:siwx": "node --experimental-test-module-mocks --test --import tsx packages/gateway/src/services/siwx-storage.test.ts packages/gateway/src/middleware/wallet-auth.test.ts packages/gateway/src/middleware/x402-siwx.test.ts",
    "test:functions": "tsx test/functions-e2e.ts",
    "test:ai": "tsx test/ai-e2e.ts",
    "test:billing": "tsx test/billing-e2e.ts",
    "test:email": "tsx test/email-e2e.ts",
    "test:mailbox": "node --experimental-test-module-mocks --test --import tsx packages/gateway/src/services/mailbox.test.ts",
    "test:sql": "node --experimental-test-module-mocks --test --import tsx packages/gateway/src/db/sql.test.ts",
    "test:docs": "tsx --test test/api-docs-alignment.test.ts",
    "test:unit": "npm run test:unit -w packages/gateway",
    "test:unit:coverage": "npm run test:unit:coverage -w packages/gateway",
    "test:magic-link": "tsx test/magic-link-e2e.ts",
    "test:sender-domain": "tsx test/sender-domain-e2e.ts",
    "test:email-billing": "tsx test/email-billing-e2e.ts",
    "test:bld402-compat": "tsx test/bld402-compat.ts",
    "lint": "eslint",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1001.0",
    "@aws-sdk/credential-providers": "^3.1001.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@x402/fetch": "^2.5.0",
    "eslint": "^10.0.2",
    "yaml": "^2.8.2"
  }
}
