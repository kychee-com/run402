# AgentDB Gateway configuration

# Wallet (generate with: npm run generate-wallets)
SELLER_ADDRESS=0x...
SELLER_PRIVATE_KEY=0x...
BUYER_PRIVATE_KEY=0x... # For E2E tests only

# JWT secret (must match PGRST_JWT_SECRET)
JWT_SECRET=super-secret-jwt-key-for-agentdb-test-only-32chars!!

# Database (local dev defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentdb
DB_USER=postgres
DB_PASSWORD=postgres

# PostgREST sidecar URL
POSTGREST_URL=http://localhost:3000

# Network: eip155:84532 (Base Sepolia testnet) or eip155:8453 (Base mainnet)
NETWORK=eip155:84532

# S3 (leave empty for local filesystem storage)
S3_BUCKET=
S3_REGION=us-east-1

# Rate limiting
RATE_LIMIT_PER_SEC=100

# Max schema slots
MAX_SCHEMA_SLOTS=2000

# PostgREST schemas (for docker-compose)
PGRST_DB_SCHEMAS=p0001,p0002,p0003,p0004,p0005,p0006,p0007,p0008,p0009,p0010

# AI helpers
OPENROUTER_API_KEY=  # Translation (via OpenRouter)
OPENAI_API_KEY=      # Moderation (free OpenAI endpoint)
